# Optional — copy to .env and adjust if needed (cp .env.example .env)
# No API keys required; everything runs locally via Ollama.

# Path to the Better Not Hundred iOS repo (must contain docs/ and Documentation/)
# Default if unset: ../Better Not Hundred (sibling folder)
# BNH_REPO_PATH=/path/to/Better Not Hundred

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
